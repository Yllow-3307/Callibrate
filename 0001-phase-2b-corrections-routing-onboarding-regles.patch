new file mode 100644
index 0000000..2c5a916
--- /dev/null
+++ b/src/features/program-engine/rules/buildSchedule.ts
@@ -0,0 +1,172 @@
+/**
+ * Moteur de construction du planning hebdomadaire.
+ *
+ * Génère des créneaux d'entraînement en tenant compte :
+ * - Des heures de réveil / travail / coucher
+ * - De la préférence horaire (matin, soir, variable)
+ * - De la durée de séance souhaitée (valeur unique en minutes)
+ * - De la fréquence hebdomadaire
+ * - Des plages d'indisponibilité déclarées par l'utilisateur
+ */
+
+import type { UserAvailability, TimeSlot, Indisponibilite } from './types'
+
+/** Jours de la semaine */
+const JOURS = ['Lundi', 'Mardi', 'Mercredi', 'Jeudi', 'Vendredi', 'Samedi', 'Dimanche'] as const
+
+/** Convertit "HH:MM" en minutes depuis minuit */
+export function timeToMinutes(time: string): number {
+  const [h, m] = time.split(':').map(Number)
+  return h * 60 + (m || 0)
+}
+
+/** Convertit des minutes depuis minuit en "HH:MM" */
+export function minutesToTime(minutes: number): string {
+  const h = Math.floor(minutes / 60)
+  const m = minutes % 60
+  return `${String(h).padStart(2, '0')}:${String(m).padStart(2, '0')}`
+}
+
+/** Vérifie si un créneau [start, end) chevauche une indisponibilité */
+function overlapsIndisponibilite(
+  slotStart: number,
+  slotEnd: number,
+  indisponibilites: Indisponibilite[],
+): boolean {
+  for (const ind of indisponibilites) {
+    const indStart = timeToMinutes(ind.debut)
+    const indEnd = timeToMinutes(ind.fin)
+    // Deux intervalles se chevauchent si startA < endB && startB < endA
+    if (slotStart < indEnd && indStart < slotEnd) {
+      return true
+    }
+  }
+  return false
+}
+
+/**
+ * Détermine les créneaux candidats selon la préférence horaire.
+ *
+ * - Matin : entre le réveil et le début du travail
+ * - Soir : entre la fin du travail et le coucher
+ * - Variable : propose les deux plages
+ */
+function getCandidateWindows(
+  availability: UserAvailability,
+): { start: number; end: number }[] {
+  const reveil = timeToMinutes(availability.heure_reveil)
+  const travailDebut = timeToMinutes(availability.heure_travail_debut)
+  const travailFin = timeToMinutes(availability.heure_travail_fin)
+  const coucher = timeToMinutes(availability.heure_coucher)
+  const duree = availability.duree_seance
+
+  const windows: { start: number; end: number }[] = []
+
+  // Fenêtre du matin : réveil → début du travail
+  const matinStart = reveil
+  const matinEnd = travailDebut
+  if (matinEnd - matinStart >= duree) {
+    windows.push({ start: matinStart, end: matinEnd })
+  }
+
+  // Fenêtre du soir : fin du travail → coucher
+  const soirStart = travailFin
+  const soirEnd = coucher
+  if (soirEnd - soirStart >= duree) {
+    windows.push({ start: soirStart, end: soirEnd })
+  }
+
+  switch (availability.preference_horaire) {
+    case 'Matin':
+      return windows.length > 0 ? [windows[0]] : []
+    case 'Soir':
+      return windows.length > 1 ? [windows[1]] : windows.length > 0 ? [windows[0]] : []
+    case 'Variable selon les jours':
+    default:
+      return windows
+  }
+}
+
+/**
+ * Trouve un créneau valide dans une fenêtre, en excluant les indisponibilités.
+ * Place le créneau au début de la fenêtre, ou juste après une indisponibilité.
+ */
+function findSlotInWindow(
+  windowStart: number,
+  windowEnd: number,
+  duree: number,
+  indisponibilites: Indisponibilite[],
+): { start: number; end: number } | null {
+  let candidate = windowStart
+
+  while (candidate + duree <= windowEnd) {
+    if (!overlapsIndisponibilite(candidate, candidate + duree, indisponibilites)) {
+      return { start: candidate, end: candidate + duree }
+    }
+    // Avancer d'un cran après l'indisponibilité qui bloque
+    for (const ind of indisponibilites) {
+      const indStart = timeToMinutes(ind.debut)
+      const indEnd = timeToMinutes(ind.fin)
+      if (candidate < indEnd && indStart < candidate + duree) {
+        candidate = indEnd
+        break
+      }
+    }
+    // Sécurité anti-boucle infinie
+    if (candidate + duree > windowEnd) break
+  }
+
+  return null
+}
+
+/**
+ * Construit le planning hebdomadaire.
+ *
+ * @param availability - Disponibilités de l'utilisateur (incluant indisponibilités)
+ * @returns Liste de créneaux attribués aux jours de la semaine
+ */
+export function buildWeeklySchedule(availability: UserAvailability): TimeSlot[] {
+  const frequence = availability.frequence_semaine
+  const duree = availability.duree_seance
+  const indisponibilites = availability.indisponibilites || []
+
+  if (frequence <= 0 || duree <= 0) return []
+
+  const windows = getCandidateWindows(availability)
+  if (windows.length === 0) return []
+
+  const slots: TimeSlot[] = []
+  let jourIndex = 0
+  let windowIndex = 0
+  let seancesPlacees = 0
+
+  while (seancesPlacees < frequence && jourIndex < JOURS.length * 2) {
+    // Protection anti-boucle
+    if (jourIndex >= JOURS.length * 2) break
+
+    const jour = JOURS[jourIndex % JOURS.length]
+    const window = windows[windowIndex % windows.length]
+
+    const slot = findSlotInWindow(window.start, window.end, duree, indisponibilites)
+
+    if (slot) {
+      // Alterner callisthenie / endurance
+      const type: 'callisthenie' | 'endurance' = seancesPlacees % 2 === 0 ? 'callisthenie' : 'endurance'
+      slots.push({
+        jour,
+        heure_debut: minutesToTime(slot.start),
+        heure_fin: minutesToTime(slot.end),
+        type,
+      })
+      seancesPlacees++
+    }
+
+    // Passer au jour suivant, alterner les fenêtres si disponible
+    jourIndex++
+    if (windows.length > 1) {
+      windowIndex++
+    }
+  }
+
+  return slots
+}
