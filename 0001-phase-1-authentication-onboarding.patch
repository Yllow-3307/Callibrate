+.progress { align-items: center; display: grid; gap: 8px; grid-template-columns: auto 1fr; color: #647067; font-size: .85rem; margin-bottom: 34px; }.progress > div { background: #e6ece4; border-radius: 20px; height: 7px; overflow: hidden; }.progress i { background: #4d955f; display: block; height: 100%; transition: width .2s; }.grid-2, .grid-3 { display: grid; gap: 16px; }.grid-2 { grid-template-columns: repeat(2, 1fr); }.grid-3 { grid-template-columns: repeat(3, 1fr); }.choice-list { display: grid; gap: 10px; }.choice { align-items: center; background: #f8faf7; border: 1px solid #dce5da; border-radius: 9px; cursor: pointer; display: flex; font-weight: 600; gap: 10px; min-height: 48px; padding: 10px 13px; }.choice input { accent-color: #2f6942; min-height: 18px; padding: 0; width: 18px; }.wizard-actions { display: flex; gap: 10px; justify-content: flex-end; margin-top: 30px; }.page-loader { align-items: center; display: flex; justify-content: center; min-height: 100vh; }
+@media (max-width: 560px) { .grid-2, .grid-3 { grid-template-columns: 1fr; }.wizard-card { padding: 26px 20px; }.progress { grid-template-columns: 1fr; }.wizard-actions { justify-content: stretch; }.wizard-actions button { flex: 1; } }
