+/** Types du moteur de règles Callibrate */
+
+/** Équipement d'une salle / parc / personnel */
+export type EquipmentType =
+  | 'Salle de sport'
+  | 'Parc de street workout'
+  | 'Équipement personnel'
+  | 'Rien'
+  | 'Poids du corps uniquement'
+
+/** Équipements personnels structurés */
+export type PersonalEquipment =
+  | 'Kettlebell'
+  | 'Barre de traction'
+  | 'Banc'
+  | 'Haltères'
+  | 'Élastique de résistance'
+  | string // "Autre" texte libre
+
+/** Équipement d'endurance */
+export type EnduranceEquipment =
+  | 'Course à pied'
+  | 'Vélo'
+  | 'Corde à sauter'
+  | 'Rameur'
+  | 'Piscine'
+
+/** Plage d'indisponibilité dans la journée */
+export type Indisponibilite = {
+  debut: string   // "HH:MM"
+  fin: string     // "HH:MM"
+  label?: string  // raison optionnelle
+}
+
+/** Profil utilisateur pour le moteur */
+export type UserProfile = {
+  age: number
+  sexe: string
+  poids: number
+  taille: number
+  niveau_sport: 'Débutant' | 'Intermédiaire' | 'Avancé' | 'Confirmé'
+  objectif: string
+}
+
+/** Équipement complet de l'utilisateur */
+export type UserEquipment = {
+  types: EquipmentType[]
+  details_perso: PersonalEquipment[]
+  equipement_endurance: EnduranceEquipment[]
+}
+
+/** Disponibilités de l'utilisateur */
+export type UserAvailability = {
+  heure_reveil: string     // "HH:MM"
+  heure_travail_debut: string
+  heure_travail_fin: string
+  heure_coucher: string
+  preference_horaire: 'Matin' | 'Soir' | 'Variable selon les jours'
+  duree_seance: number     // minutes (valeur unique)
+  frequence_semaine: number
+  indisponibilites: Indisponibilite[]
+}
+
+/** Exercice de la bibliothèque */
+export type Exercise = {
+  id: string
+  nom: string
+  categorie: string
+  equipement_requis: string[]   // ex. ['Barre de traction'] ou ['Salle de sport']
+  niveau: string                // 'Débutant' | 'Intermédiaire' | 'Avancé' | 'Confirmé'
+  muscle_cible: string
+}
+
+/** Créneau horaire dans le planning */
+export type TimeSlot = {
+  jour: string      // 'Lundi', 'Mardi', etc.
+  heure_debut: string  // "HH:MM"
+  heure_fin: string
+  type: 'callisthenie' | 'endurance'
+}
