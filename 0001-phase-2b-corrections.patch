diff --git a/supabase/migrations/0002_add_indisponibilites.sql b/supabase/migrations/0002_add_indisponibilites.sql
new file mode 100644
index 0000000..3f10a20
--- /dev/null
+++ b/supabase/migrations/0002_add_indisponibilites.sql
@@ -0,0 +1,31 @@
+-- Migration additive : ajout de la colonne indisponibilites à availability
+-- et adaptation des colonnes equipment pour des structures de données structurées.
+
+-- 1. Ajout de la colonne indisponibilites (jsonb, tableau d'objets {debut, fin, label})
+ALTER TABLE public.availability
+  ADD COLUMN IF NOT EXISTS indisponibilites jsonb DEFAULT '[]'::jsonb;
+
+-- 2. Changement du type de details_perso : texte libre -> jsonb (tableau de valeurs)
+-- On passe d'un champ texte libre à un tableau JSON des équipements personnels sélectionnés.
+-- Les données existantes (texte libre) sont conservées dans un tableau d'un élément pour ne rien perdre.
+ALTER TABLE public.equipment
+  ALTER COLUMN details_perso TYPE jsonb
+  USING CASE
+    WHEN details_perso IS NULL THEN '[]'::jsonb
+    ELSE jsonb_build_array(details_perso)
+  END;
+
+ALTER TABLE public.equipment
+  ALTER COLUMN details_perso SET DEFAULT '[]'::jsonb;
+
+-- 3. Changement du type de equipement_endurance : texte -> jsonb (tableau de valeurs)
+-- Permet de stocker plusieurs équipements d'endurance au lieu d'un seul.
+ALTER TABLE public.equipment
+  ALTER COLUMN equipement_endurance TYPE jsonb
+  USING CASE
+    WHEN equipement_endurance IS NULL THEN '[]'::jsonb
+    ELSE jsonb_build_array(equipement_endurance)
+  END;
+
+ALTER TABLE public.equipment
+  ALTER COLUMN equipement_endurance SET DEFAULT '[]'::jsonb;
