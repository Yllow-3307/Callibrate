+/**
+ * Moteur de sélection d'exercices.
+ *
+ * Compare l'équipement de l'utilisateur (tableaux de valeurs structurées)
+ * avec l'équipement requis par chaque exercice de la bibliothèque,
+ * et filtre selon le niveau de l'utilisateur.
+ */
+
+import type { Exercise, UserEquipment, UserProfile } from './types'
+
+/** Niveaux ordonnés du moins au plus avancé */
+const NIVEAU_ORDER = ['Débutant', 'Intermédiaire', 'Avancé', 'Confirmé'] as const
+
+function niveauIndex(niveau: string): number {
+  const idx = NIVEAU_ORDER.indexOf(niveau as (typeof NIVEAU_ORDER)[number])
+  return idx === -1 ? 0 : idx
+}
+
+/**
+ * Détermine si l'équipement de l'utilisateur couvre l'équipement requis
+ * par un exercice donné.
+ *
+ * Logique :
+ * - Si l'exercice ne requiert aucun équipement (corps libre), il est toujours sélectionnable.
+ * - Si l'exercice requiert "Poids du corps uniquement", il est sélectionnable si l'utilisateur
+ *   a coché "Poids du corps uniquement" OU "Rien" OU n'a aucun équipement spécifique.
+ * - Si l'exercice requiert un équipement spécifique (ex. "Barre de traction"),
+ *   l'utilisateur doit l'avoir dans son tableau `details_perso` OU avoir coché
+ *   "Salle de sport" ou "Parc de street workout" (qui fournissent tout).
+ * - Si l'exercice requiert "Salle de sport", l'utilisateur doit l'avoir coché.
+ */
+export function hasRequiredEquipment(
+  exercise: Exercise,
+  userEquipment: UserEquipment,
+): boolean {
+  const requis = exercise.equipement_requis
+
+  // Exercice sans équipement spécifique
+  if (!requis || requis.length === 0) return true
+
+  // Si l'utilisateur a une salle de sport ou un parc, il a accès à tout
+  const hasFullAccess =
+    userEquipment.types.includes('Salle de sport') ||
+    userEquipment.types.includes('Parc de street workout')
+
+  for (const req of requis) {
+    const reqLower = req.toLowerCase().trim()
+
+    // Équipement de base (corps libre)
+    if (reqLower === 'aucun' || reqLower === 'poids du corps' || reqLower === 'poids du corps uniquement') {
+      // Accessible à tous
+      continue
+    }
+
+    // Accès complet salle/parc couvre tout sauf les équipements très spécifiques
+    if (hasFullAccess) continue
+
+    // Vérifier dans les équipements personnels
+    const matchesPersonal = userEquipment.details_perso.some(
+      (perso) => perso.toLowerCase().trim() === reqLower,
+    )
+    if (matchesPersonal) continue
+
+    // L'équipement requis n'est pas couvert
+    return false
+  }
+
+  return true
+}
+
+/**
+ * Vérifie si le niveau de l'utilisateur est suffisant pour un exercice.
+ * Autorise les exercices à un niveau égal ou inférieur au niveau de l'utilisateur.
+ */
+function niveauSuffisant(userNiveau: string, exerciseNiveau: string): boolean {
+  return niveauIndex(userNiveau) >= niveauIndex(exerciseNiveau)
+}
+
+/**
+ * Sélectionne les exercices compatibles avec le profil et l'équipement
+ * de l'utilisateur.
+ *
+ * @param exercises - Bibliothèque complète d'exercices
+ * @param profile - Profil de l'utilisateur (niveau, objectif)
+ * @param equipment - Équipement structuré de l'utilisateur
+ * @returns Liste filtrée d'exercices compatibles
+ */
+export function selectExercisesForProfile(
+  exercises: Exercise[],
+  profile: UserProfile,
+  equipment: UserEquipment,
+): Exercise[] {
+  return exercises.filter((exercise) => {
+    // 1. Vérifier le niveau
+    if (!niveauSuffisant(profile.niveau_sport, exercise.niveau)) {
+      return false
+    }
+
+    // 2. Vérifier l'équipement
+    if (!hasRequiredEquipment(exercise, equipment)) {
+      return false
+    }
+
+    return true
+  })
+}
